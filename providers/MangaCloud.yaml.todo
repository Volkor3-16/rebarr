search:
  steps:
    - open: "{base_url}"
    - fetch:
        url: "https://api.mangacloud.org/comic/browse"
        method: POST
        headers:
          User-Agent: "Mozilla/5.0 (X11; Linux x86_64; rv:148.0) Gecko/20100101 Firefox/148.0"
          Accept: "*/*"
          Accept-Language: "en-US,en;q=0.9"
          Referer: "https://mangacloud.org/"
          Origin: "https://mangacloud.org"
          Content-Type: "application/json"
        body: '{"title":"{query}","page":1}'
        var: search_data
        json_path: data
    - extract_js:
        var: search_processed
        script: |
          (function() {
            try {
              var raw = '{search_data|js_escape}';
              var mangas = JSON.parse(raw);
              if (!Array.isArray(mangas)) {
                return '[]';
              }
              var processed = mangas.map(function(m) {
                var coverUrl = '';
                if (m.cover && m.cover.id && m.cover.f) {
                  coverUrl = 'https://pika.mangacloud.org/' + m.id + '/cover.' + m.cover.f;
                }
                return {
                  title: m.title || '',
                  url: m.id || '',
                  cover: coverUrl
                };
              });
              return JSON.stringify(processed);
            } catch (e) {
              return '[]';
            }
          })()
    - from_json:
        var: search_processed
        extract:
          title: "title"
          url: "url"
          cover: "cover"
        prefix:
          url: "https://mangacloud.org/comic/"

chapters:
  steps:
    - open: "{base_url}"
    - fetch:
        url: "https://api.mangacloud.org/comic/{manga_url|basename}"
        method: GET
        headers:
          User-Agent: "Mozilla/5.0 (X11; Linux x86_64; rv:148.0) Gecko/20100101 Firefox/148.0"
          Accept: "*/*"
          Referer: "https://mangacloud.org/"
          Origin: "https://mangacloud.org"
        var: manga_data
        json_path: "data.chapters"
    - extract_js:
        var: chapters_processed
        script: |
          (function() {
            try {
              var raw = '{manga_data|js_escape}';
              var chapters = JSON.parse(raw);
              if (!Array.isArray(chapters)) {
                return '[]';
              }
              var comicId = '{manga_url|basename}';
              var processed = chapters.map(function(ch) {
                var chapterName = 'Chapter ' + (ch.number ? ch.number.toString().replace(/\.0$/, '') : '');
                if (ch.name) {
                  chapterName += ' - ' + ch.name;
                }
                return {
                  number_raw: ch.number ? ch.number.toString() : '',
                  title: chapterName,
                  url: JSON.stringify({comicId: comicId, chapterId: ch.id}),
                  date: ch.date ? Math.floor(ch.date / 1000).toString() : ''
                };
              });
              return JSON.stringify(processed);
            } catch (e) {
              return '[]';
            }
          })()
    - from_json:
        var: chapters_processed
        extract:
          number_raw: "number_raw"
          title: "title"
          url: "url"
          date: "date"
        date_format:
          date: "%+"

pages:
  steps:
    - open: "{base_url}"
    - extract_js:
        var: page_urls
        script: |
          (async () => {
            try {
              var chapterData = JSON.parse('{chapter_url}');
              var comicId = chapterData.comicId;
              var chapterId = chapterData.chapterId;
              const resp = await fetch('https://api.mangacloud.org/chapter/' + chapterId, {
                headers: {
                  'User-Agent': 'Mozilla/5.0 (X11; Linux x86_64; rv:148.0) Gecko/20100101 Firefox/148.0',
                  'Accept': '*/*',
                  'Referer': 'https://mangacloud.org/',
                  'Origin': 'https://mangacloud.org'
                }
              });
              const data = await resp.json();
              const chapterContent = data.data || {};
              const images = chapterContent.images || [];
              const urls = images.map(function(img) {
                return 'https://pika.mangacloud.org/' + comicId + '/' + chapterId + '/' + img.id + '.' + img.format;
              });
              return JSON.stringify(urls);
            } catch(e) {
              return '[]';
            }
          })()
    - return: "{page_urls}"
