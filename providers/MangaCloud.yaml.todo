name: MangaCloud
base_url: https://mangacloud.org/
version: "1"
default_score: 30 # Small Library, Good Quality
tags:
  - hub
rate_limit:
  requests_per_minute: 30

# curl 'https://api.mangacloud.org/search' \
#   --compressed \
#   -X POST \
#   -H 'User-Agent: Mozilla/5.0 (X11; Linux x86_64; rv:148.0) Gecko/20100101 Firefox/148.0' \
#   -H 'Accept: */*' \
