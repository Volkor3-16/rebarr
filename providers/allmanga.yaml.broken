name: All Manga
base_url: https://allmanga.to
rate_limit:
  requests_per_minute: 30

search:
  steps:
    - open: "/search-manga?cty=ALL&query={query}"
    - foreach:
        selector: ".card.card-manga-item"
        extract:
          title:
            selector: ".card-header a"
            content: text
          url:
            selector: ".card-header a"
            content: attr
            attr_name: href
            prefix: "{base_url}"
          cover:
            selector: ".img-container img"
            content: attr
            attr_name: src

# Broken - api is kinda fucked and uses graphql, and cloudflare blocks direct access.
# https://github.com/keiyoushi/extensions-source/tree/main/src/en/allanime/src/eu/kanade/tachiyomi/extension/en/allanime

chapters:
  steps:
    - open: "{manga_url}"
    - foreach:
        selector: "div[x-data] > a"
        extract:
          number_raw:
            selector: "span:nth-child(2) > span:first-child"
            content: text
          # Disabled title extraction, since weebcentral doesn't use them.
          # title:
          #   selector: "span.flex > span"
          #   content: text
          url:
            selector: ""
            content: attr
            attr_name: href
            prefix: "{base_url}"
          scanlator_group:
            selector: "svg"
            content: attr
            attr_name: stroke
            value_map:
              "#d8b4fe": "Official"
              "#4C4D54": "Unknown Scanlator"

pages:
  steps:
    - open: "{chapter_url}/images?is_prev=False&reading_style=long_strip"
    - foreach:
        selector: "img"
        extract:
          url:
            selector: ""
            content: attr
            attr_name: src
